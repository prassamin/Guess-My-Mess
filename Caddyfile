{
    admin off
}

:3000 {
    # All /v1/* traffic (Socket.io + future API routes) goes to backend
    @backend {
        path /v1/* /health
    }
    handle @backend {
        reverse_proxy localhost:{$BACKEND_PORT:8000}
    }

    # Everything else goes to Next.js frontend
    handle {
        reverse_proxy localhost:3001
    }
}
